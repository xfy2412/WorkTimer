<Window x:Class="WorkTimer.Overlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        Width="220" Height="100"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        Opacity="0.15">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.15" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem x:Name="TogglePauseItem" Header="暂停" Click="TogglePause_Click"/>
            <Separator/>
            <MenuItem Header="重置计时" Click="Reset_Click"/>
            <Separator/>
            <MenuItem Header="查看统计" Click="OpenStats_Click"/>
            <MenuItem Header="设置" Click="OpenSettings_Click"/>
            <Separator/>
            <MenuItem Header="退出" Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Border x:Name="CardBorder" CornerRadius="12" Background="#2D2D2D" BorderThickness="1" BorderBrush="#555555">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 拖拽手柄 -->
                <Border x:Name="DragHandle" Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="DragHandle_MouseDown"
                        ToolTip="拖拽移动">
                    <Grid>
                        <TextBlock x:Name="HamburgerIcon" Text="☰☰☰"
                                   Foreground="#666666" FontSize="10"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border x:Name="SeparatorLine" Height="1" Background="#444444"
                                VerticalAlignment="Bottom" Margin="6,0,6,0"/>
                    </Grid>
                </Border>
                <!-- 计时内容 -->
                <Grid Grid.Row="1" Margin="12,4,12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TimeText" Grid.Row="0"
                               Foreground="White" FontSize="26"
                               FontWeight="SemiBold" FontFamily="Consolas"
                               HorizontalAlignment="Center"
                               Text="00:00:00"/>
                    <TextBlock x:Name="StatusText" Grid.Row="1"
                               Foreground="#AAAAAA" FontSize="11"
                               HorizontalAlignment="Center"
                               Text="工作中" Margin="0,0,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
