<Page x:Class="WorkTimer_Settings.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="24,16" Spacing="16">
            <TextBlock Text="系统设置" Style="{StaticResource TitleTextBlockStyle}"/>

            <ToggleSwitch x:Name="AutoStartToggle" Header="开机自启"
                          OffContent="关闭" OnContent="开启"/>
            <ToggleSwitch x:Name="AlwaysContinueToggle" Header="开机自动续接（跳过确认）"
                          OffContent="关闭" OnContent="开启"/>
            <TextBlock Text="计时数据存储在本地 SQLite 数据库中" Foreground="#888" FontSize="12"/>
            <Button x:Name="OpenDataFolder" Content="打开数据文件夹" Click="OpenDataFolder_Click"/>
        </StackPanel>
    </ScrollViewer>
</Page>
